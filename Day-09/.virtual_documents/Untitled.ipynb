import numpy as np
import time



#execution performance
size = 1_000_00

#python list
py_list = list(range(size))
start = time.time()
sq_list = [x**2 for x in py_list]
end = time.time()
print(f"python list time = {end - start} second")

#numpy arrays 
np_arr = np.array(py_list)
start = time.time()
sq_array = np_arr ** 2
end = time.time()
print(f"python list time = {end-start} seconds")


#memory
import sys

print(f"python list size = {sys.getsized(py_list)*len(py_list)}bytes")

print(f"numpy array size = {np_arr.nbytes}bytes")



